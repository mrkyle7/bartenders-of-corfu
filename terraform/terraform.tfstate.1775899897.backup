                            "content": "logging:\n  receivers:\n    k3s_container_logs:\n      type: files\n      include_paths:\n        - /var/log/pods/*/*/*.log\n      record_log_file_path: true\n  processors:\n    # CRI log format written by k3s/containerd:\n    #   2024-01-01T00:00:00.000000000Z stdout F {\"severity\":\"INFO\",\"message\":\"...\"}\n    parse_cri:\n      type: parse_regex\n      field: message\n      regex: '^(?\u003ctime\u003e\\S+) (?\u003cstream\u003estdout|stderr) [FP] (?\u003clog\u003e.*)$'\n      time_key: time\n      time_format: '%Y-%m-%dT%H:%M:%S.%L%z'\n    # Parse the JSON payload the app emits into top-level fields.\n    # Cloud Logging recognises `severity`, `message`, `timestamp`, etc.\n    parse_app_json:\n      type: parse_json\n      field: log\n  service:\n    pipelines:\n      k3s_pipeline:\n        receivers: [k3s_container_logs]\n        processors: [parse_cri, parse_app_json]\n",
                            "file": [],
                            "path": "/etc/google-cloud-ops-agent/config.yaml",
