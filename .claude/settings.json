{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/pre-session.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/run-relevant-tests.sh"
          }
        ]
      }
    ],
    "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "uv run ruff check && uv run ruff format --check"
        }
      ]
    }
  ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "allium@juxt-plugins": true
  }
}
